menu "OTA"

config LOT_OTA_URL
    string "OTA image URL (http/https)"
    default ""
    help
        Firmware URL generated by idf.py build. Empty means OTA is skipped.

config LOT_OTA_VERSION_URL
    string "OTA version URL (http/https, text)"
    default ""
    help
        URL that returns latest firmware version text, e.g. "1.2.3".

config LOT_OTA_HTTP_TIMEOUT_MS
    int "OTA HTTP timeout (ms)"
    range 1000 120000
    default 10000
    help
        Timeout used by HTTP client during OTA.

config LOT_OTA_RESTART_ON_SUCCESS
    bool "Restart after OTA success"
    default y
    help
        Restart immediately after a successful OTA update.

endmenu
