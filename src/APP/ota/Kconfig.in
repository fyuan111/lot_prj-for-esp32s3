menu "OTA"

config LOT_OTA_AUTO_CHECK_ON_BOOT
    bool "Auto check OTA at boot"
    default y
    help
        If enabled, device checks OTA URL after Wi-Fi connected.

config LOT_OTA_URL
    string "OTA image URL (HTTPS)"
    default "https://example.com/lot_prj.bin"
    help
        HTTPS URL for firmware image generated by idf.py build.

config LOT_OTA_HTTP_TIMEOUT_MS
    int "OTA HTTP timeout (ms)"
    range 1000 120000
    default 10000
    help
        Timeout used by HTTP client during OTA.

endmenu
